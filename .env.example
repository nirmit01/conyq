# ─── AI Provider (pick one) ───────────────────────────────────────
# Leave empty to use built-in mock responses (no API key needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider to use: "openai" | "anthropic" | "mock"
AI_PROVIDER=mock

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="My ET"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_PATH=./data/my-et.db

# ─── News API (optional — mock data used if absent) ───────────────
NEWS_API_KEY=
